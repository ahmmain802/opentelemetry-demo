  "interactions": [
    {
      "description": "a request for shipping quote that returns malformed JSON",
      "providerState": "shipping service returns malformed response",
      "request": {
        "body": {
          "address": {
            "city": "Mountain View",
            "country": "United States",
            "state": "CA",
            "street_address": "1600 Amphitheatre Parkway",
            "zip_code": "94043"
          },
          "items": [
            {
              "product_id": "OLJCESPC7Z",
              "quantity": 1
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "$.body.address": {
            "match": "type"
          },
          "$.body.items": {
            "match": "type",
            "min": 1
          },
          "$.body.items[*].product_id": {
            "match": "type"
          },
          "$.body.items[*].quantity": {
            "match": "type"
          }
        },
        "method": "POST",
        "path": "/get-quote"
      },
      "response": {
        "body": "Internal Server Error",
        "headers": {
          "Content-Type": "text/plain"
        },
        "status": 500
      }
    },
    {
      "description": "a request for shipping quote with empty items array",
